# ─────────────────────────────────────────────────────
# Good First Issue Tracker — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Secrets are NEVER baked into the Docker image.
# They are injected at runtime via:
#   - Local:   docker compose up  (reads .env automatically)
#   - Coolify: Set in the Environment Variables tab
#   - Direct:  docker run --env-file .env <image>
# ─────────────────────────────────────────────────────

# ── Required ──

# Discord webhook URL for notifications
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# GitHub Personal Access Token (recommended — without it you get
# only 10 search requests/min instead of 30)
GITHUB_TOKEN=your_github_token_here

# ── Optional (with defaults) ──

# Polling interval in seconds (default: 7200 = 2 hours)
POLL_INTERVAL=7200

# First-run lookback in hours (default: 12)
FIRST_RUN_LOOKBACK_HOURS=12

# ── Performance tuning ──

# Number of concurrent GitHub API workers (default: 5)
MAX_GITHUB_WORKERS=5

# Number of repos per search query chunk (default: 50, max ~50)
CHUNK_SIZE=50

# Number of latest repos to fetch per org (default: 10)
ORG_REPO_LIMIT=10
