# Discord webhook URL for notifications
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# GitHub Personal Access Token (recommended for higher rate limits)
GITHUB_TOKEN=your_github_token_here

# Polling interval in seconds (default: 3600 = 1 hour)
POLL_INTERVAL=3600

# First-run lookback in hours (default: 12)
FIRST_RUN_LOOKBACK_HOURS=12

# ── Performance tuning ──
# Number of concurrent GitHub API workers (default: 10)
MAX_GITHUB_WORKERS=5

# Number of repos per search query chunk (default: 50, max ~50)
CHUNK_SIZE=50

# Number of latest repos to fetch per org (default: 10)
ORG_REPO_LIMIT=10
